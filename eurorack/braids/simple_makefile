TARGET = braids_wav_generator

$(TARGET): $(CC_FILES)
	g++ -DTEST -g -Wall -Wno-unused-variable -I. -I../../.. -o $(TARGET) $(CC_FILES)

clean:
	rm -f $(TARGET)

.PHONY: clean